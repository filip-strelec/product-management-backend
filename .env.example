PORT=3000
NODE_ENV=development
DATABASE_FILE=./data/products.db
CORS_ORIGIN=http://localhost:4200

# Set to `true` when the API runs behind a reverse proxy (nginx, ELB, ...)
# so X-Forwarded-Proto / X-Forwarded-Host are honored. Required for the
# upload endpoint to return correct https URLs in production.
TRUST_PROXY=false

# --- Seed data (optional) -------------------------------------------------
# When `false` (default), the API auto-seeds from DummyJSON on first boot.
# When `true`, it loads the bundled fixtures in src/db/seedValues/ instead
# (seedCategories.json + seedProducts.json — see that folder's README).
SEED_FROM_LOCAL_FILES=false

# --- Thumbnail uploads ----------------------------------------------------
# Where uploaded thumbnails are written on disk and the max accepted size.
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_BYTES=1048576
