PORT=3000
NODE_ENV=development
DATABASE_FILE=./data/products.db
CORS_ORIGIN=http://localhost:4200

# Set to `true` when the API runs behind a reverse proxy (nginx, ELB, ...)
# so X-Forwarded-Proto / X-Forwarded-Host are honored. Required for the
# upload endpoint to return correct https URLs in production.
TRUST_PROXY=false

# --- Seed data (optional) -------------------------------------------------
# When unset, the API auto-seeds from DummyJSON on first boot.
# Set either of these to a JSON file path to seed from disk instead.
# Example files live in src/db/seedValues/ — see that folder's README.
# SEED_CATEGORIES_FILE=./src/db/seedValues/seedCategories.json
# SEED_PRODUCTS_FILE=./src/db/seedValues/seedProducts.json

# --- Thumbnail uploads ----------------------------------------------------
# Where uploaded thumbnails are written on disk and the max accepted size.
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_BYTES=1048576
